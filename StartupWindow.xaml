<Window x:Class="MagDbPatcher.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Starting ME_ACS SQL Patcher"
        Width="468"
        Height="244"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        AllowsTransparency="True"
        Icon="/Assets/me-acs-patcher.ico">
    <Border Margin="18"
            Padding="20"
            Background="{StaticResource BgSecondary}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="62"
                        Height="62"
                        Background="{StaticResource BrandAccentSoft}"
                        BorderBrush="{StaticResource BrandAccentLine}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="10">
                    <Image Source="/Assets/me-acs-patcher.png"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="16,2,0,0">
                    <TextBlock Text="ME_ACS SQL Patcher"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="txtBuildVersion"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,6,0,0"/>
                    <TextBlock Text="Preparing the portable support workspace and validating the patch library."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="16"
                    Background="{StaticResource SurfaceSubtle}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Startup status"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="txtStatus"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,8,0,10"
                               TextWrapping="Wrap"/>
                    <ProgressBar IsIndeterminate="True"
                                 Style="{StaticResource ModernProgressBar}"
                                 Height="10"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,16,0,0"
                       Text="If the app is already open, launching again will bring the existing window forward."
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
