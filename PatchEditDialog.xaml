<Window x:Class="MagDbPatcher.PatchEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patch Editor"
        Height="470" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Patch Details" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,8"/>
                <TextBlock Text="From Version" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbFromVersion" Style="{StaticResource DarkComboBox}" FontSize="13" DisplayMemberPath="Name"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="To Version" Style="{StaticResource FieldLabelText}" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbToVersion" Style="{StaticResource DarkComboBox}" FontSize="13" DisplayMemberPath="Name"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,8">
            <TextBlock Text="Scripts" Style="{StaticResource SectionHeaderText}" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtScriptCount" Text="" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="3" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="lstScripts" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" SelectionChanged="LstScripts_SelectionChanged"/>

                <StackPanel Grid.Column="1" Margin="8,0,0,0" Width="84">
                    <Button x:Name="btnAddScript" Content="+ Add" Style="{StaticResource BtnSecondary}" Padding="8,6" Margin="0,0,0,4" Click="BtnAddScript_Click"/>
                    <Button x:Name="btnRemoveScript" Content="Remove" Style="{StaticResource BtnDanger}" Padding="8,6" Margin="0,0,0,4" IsEnabled="False" Click="BtnRemoveScript_Click"/>
                    <Button x:Name="btnMoveUp" Content="&#x2191; Up" Style="{StaticResource BtnSecondary}" Padding="8,6" Margin="0,0,0,4" IsEnabled="False" Click="BtnMoveUp_Click"/>
                    <Button x:Name="btnMoveDown" Content="&#x2193; Down" Style="{StaticResource BtnSecondary}" Padding="8,6" IsEnabled="False" Click="BtnMoveDown_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" Padding="16,8" IsCancel="True" Click="BtnCancel_Click"/>
            <Button x:Name="btnSave" Content="Save" Style="{StaticResource BtnPrimary}" Padding="16,8" Margin="10,0,0,0" IsDefault="True" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
