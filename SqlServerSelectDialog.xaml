<Window x:Class="MagDbPatcher.SqlServerSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select SQL Server"
        Height="260" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        ResizeMode="NoResize">
    <Border Style="{StaticResource Card}" Margin="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Could not auto-detect SQL Server. Enter a server name to try:" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <ComboBox x:Name="cmbServer" Grid.Row="1" IsEditable="True" Style="{StaticResource DarkEditableComboBox}" FontSize="13" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="btnTest" Content="Test Connection" Style="{StaticResource BtnSecondary}" Padding="12,6" Click="BtnTest_Click"/>
                <TextBlock x:Name="txtResult" Foreground="{StaticResource TextMuted}" Margin="10,6,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="3" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Text="Examples: .\SQLEXPRESS, (localdb)\MSSQLLocalDB, localhost" Margin="0,6,0,0"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancel" Style="{StaticResource BtnSecondary}" Padding="16,8" IsCancel="True" Click="BtnCancel_Click"/>
                <Button x:Name="btnOk" Content="OK" Style="{StaticResource BtnPrimary}" Padding="16,8" Margin="10,0,0,0" IsDefault="True" IsEnabled="False" Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
