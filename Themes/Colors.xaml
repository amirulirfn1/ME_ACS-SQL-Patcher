<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Brand -->
    <SolidColorBrush x:Key="BrandPrimary" Color="#EEF3FA"/>
    <SolidColorBrush x:Key="BrandPrimarySoft" Color="#E5ECF6"/>
    <SolidColorBrush x:Key="BrandAccent" Color="#2E6FE8"/>
    <SolidColorBrush x:Key="BrandAccentSoft" Color="#EAF1FF"/>
    <SolidColorBrush x:Key="BrandAccentLine" Color="#5F8FEF"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BgPrimary" Color="#D8E1EE"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#EEF3F9"/>
    <SolidColorBrush x:Key="BgTertiary" Color="#E3EAF3"/>
    <SolidColorBrush x:Key="SurfaceRaised" Color="#F2F6FB"/>
    <SolidColorBrush x:Key="SurfaceSubtle" Color="#E9EFF7"/>
    <SolidColorBrush x:Key="SurfaceHover" Color="#DFE8F4"/>
    <SolidColorBrush x:Key="SurfacePressed" Color="#D6E0EF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#AFC0D8"/>
    <SolidColorBrush x:Key="BorderStrong" Color="#90A8CB"/>
    <SolidColorBrush x:Key="FocusRing" Color="#4E7FCB"/>

    <!-- Semantic -->
    <SolidColorBrush x:Key="Success" Color="#1F9A63"/>
    <SolidColorBrush x:Key="SuccessSoft" Color="#DDF3E6"/>
    <SolidColorBrush x:Key="Info" Color="#2E6FE8"/>
    <SolidColorBrush x:Key="InfoSoft" Color="#DFEAFD"/>
    <SolidColorBrush x:Key="Warning" Color="#B57A16"/>
    <SolidColorBrush x:Key="WarningSoft" Color="#F8EBCF"/>
    <SolidColorBrush x:Key="Error" Color="#CC3D3D"/>
    <SolidColorBrush x:Key="ErrorSoft" Color="#F7DEDE"/>

    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary" Color="#10243C"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#2F4F72"/>
    <SolidColorBrush x:Key="TextMuted" Color="#567294"/>
    <SolidColorBrush x:Key="TextInverse" Color="#FFFFFF"/>

    <!-- Compatibility aliases -->
    <SolidColorBrush x:Key="AccentGreen" Color="#1F9A63"/>
    <SolidColorBrush x:Key="AccentGreenHover" Color="#178553"/>
    <SolidColorBrush x:Key="AccentBlue" Color="#2E6FE8"/>
    <SolidColorBrush x:Key="AccentRed" Color="#CC3D3D"/>

    <SolidColorBrush x:Key="SelectionBg" Color="#2E6FE8"/>
    <SolidColorBrush x:Key="SelectionFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ProgressFillStart" Color="#2E6FE8"/>
    <SolidColorBrush x:Key="ProgressFillEnd" Color="#1F9A63"/>
</ResourceDictionary>
