<Window x:Class="MagDbPatcher.VersionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Version Editor"
        Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        ResizeMode="NoResize">
    <Border Style="{StaticResource Card}" Margin="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Version ID" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <TextBox x:Name="txtVersionId" Grid.Column="1" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" Text="Display Name" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <TextBox x:Name="txtVersionName" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="2" Text="Upgrades To" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbUpgradesTo" Grid.Row="2" Grid.Column="1" Style="{StaticResource DarkComboBox}" DisplayMemberPath="Display" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0" Text="Leave 'Upgrades To' as Latest if this version has no next upgrade." FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>

            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancel" Style="{StaticResource BtnSecondary}" Padding="16,8" IsCancel="True" Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" Content="Save" Style="{StaticResource BtnPrimary}" Padding="16,8" Margin="10,0,0,0" IsDefault="True" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
